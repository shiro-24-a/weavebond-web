---
// src/components/Interviewer.astro
//
// 使い方:
//   <Interviewer question="あなたの強みを教えてください。">
//     補足の説明や追加テキストを入れることもできます（省略可）
//   </Interviewer>
//
// Props:
//   question  : string  — 面接官の発言テキスト（必須）
//   label     : string  — 左上のラベル（省略時 "面接官"）
//   number    : number  — 設問番号。指定すると "Q1" のようにラベルへ付加

interface Props {
  question: string;
  label?: string;
  number?: number;
}

const {
  question,
  label = "面接官",
  number,
} = Astro.props;

const displayLabel = number != null ? `${label} — Q${number}` : label;
---

<div class="interviewer">
  <span class="interviewer__label">{displayLabel}</span>
  <div class="interviewer__bubble">
    <p class="interviewer__text">{question}</p>
    <!-- 追加コンテンツ（補足説明など）があればここに入る -->
    <slot />
  </div>
</div>

<style>
  /* ─────────────────────────────────────────────────────────────
     面接官ブロック
     ・左寄せ配置
     ・グレー背景（議事録の質問欄として落ち着いた印象）
     ・角丸を右側だけ全適用し、左上を角張らせて"吹き出し起点"を示す
  ───────────────────────────────────────────────────────────── */

  .interviewer {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: .6rem;
    margin: 2.8rem 0;
  }

  .interviewer__label {
    font-family: "Syne", sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-muted, #666666);

    display: flex;
    align-items: center;
    gap: .5rem;
    padding-left: .1rem;
  }

  /* ラベル左の短い水平線 — 議事録の項目マーカー */
  .interviewer__label::before {
    content: "";
    display: inline-block;
    width: 16px;
    height: 1px;
    background: var(--border-mid, rgba(0,0,0,.18));
    flex-shrink: 0;
  }

  .interviewer__bubble {
    background: rgba(0,0,0,.038);
    border: 1px solid var(--border, rgba(0,0,0,.10));

    /* 左上は角張らせて、残り3角は丸める */
    border-radius: 0 8px 8px 8px;

    padding: 1.3rem 1.6rem;
    max-width: 86%;
    position: relative;
  }

  /* 左上の角に1pxのアンバーアクセント線 */
  .interviewer__bubble::before {
    content: "";
    position: absolute;
    top: -1px;
    left: -1px;
    width: 28px;
    height: 2px;
    background: var(--border-mid, rgba(0,0,0,.18));
    border-radius: 1px;
  }

  .interviewer__text {
    font-family: "Noto Serif JP", serif;
    font-size: 1.05rem !important;
    line-height: 2 !important;
    color: var(--ink, #111111) !important;
    margin: 0 !important;
    font-weight: 500;
  }

  /* slot 内コンテンツ（補足テキストなど）*/
  .interviewer__bubble :global(p) {
    font-size: .9rem;
    line-height: 1.9;
    color: var(--ink-muted, #666666);
    margin-top: .7rem;
    margin-bottom: 0;
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .interviewer__bubble {
      max-width: 100%;
    }

    .interviewer__text {
      font-size: 1rem !important;
    }
  }
</style>