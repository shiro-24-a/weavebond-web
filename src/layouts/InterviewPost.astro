---
// src/layouts/InterviewPost.astro

const { frontmatter } = Astro.props;

const date = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("ja-JP", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

const sessionLabel = frontmatter.sessionNumber
  ? `第${frontmatter.sessionNumber}回`
  : null;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{frontmatter.title} | AI採用面接シリーズ — AIとの付き合い方研究所</title>

  {frontmatter.description && (
    <meta name="description" content={frontmatter.description} />
  )}

  <style>
    /* ─────────────────────────────────────────────────────────────
       DESIGN TOKENS — BlogPost.astro と完全に同一の変数体系
    ───────────────────────────────────────────────────────────── */
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Noto+Serif+JP:wght@400;500;600&family=Noto+Sans+JP:wght@400;500&display=swap');

    :root {
      --ink:        #111111;
      --ink-soft:   #2b2b2b;
      --ink-muted:  #666666;

      --paper:      #f7f4ee;
      --paper-card: #fcfaf6;

      --amber:      #c87c22;
      --amber-light: rgba(200,124,34,.08);
      --amber-line:  rgba(200,124,34,.35);

      --border:     rgba(0,0,0,.10);
      --border-mid: rgba(0,0,0,.18);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: "Noto Sans JP", sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* ─────────────────────────────────────────────────────────────
       SITE HEADER — BlogPost.astro と同構造
    ───────────────────────────────────────────────────────────── */

    .site-header {
      border-bottom: 1px solid var(--border);
      background: rgba(247,244,238,.95);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .site-header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .site-logo {
      font-family: "Noto Serif JP", serif;
      font-size: .85rem;
      font-weight: 600;
      color: var(--ink-soft);
      letter-spacing: .06em;
    }

    .site-logo span {
      color: var(--amber);
    }

    .back-link {
      font-size: .8rem;
      color: var(--ink-muted);
      transition: color .15s;
    }

    .back-link:hover {
      color: var(--amber);
    }

    /* ─────────────────────────────────────────────────────────────
       SERIES BAND — シリーズ固有の細帯。議事録の表紙のような役割
    ───────────────────────────────────────────────────────────── */

    .series-band {
      background: var(--ink);
    }

    .series-band-inner {
      max-width: 760px;
      margin: 0 auto;
      padding: .6rem 1.5rem;
      display: flex;
      align-items: center;
      gap: .9rem;
    }

    .series-band-label {
      font-family: "Syne", sans-serif;
      font-size: .6rem;
      font-weight: 700;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--amber);
    }

    .series-band-divider {
      width: 1px;
      height: .8em;
      background: rgba(255,255,255,.18);
      flex-shrink: 0;
    }

    .series-band-sub {
      font-size: .7rem;
      color: rgba(247,244,238,.5);
      letter-spacing: .04em;
    }

    /* ─────────────────────────────────────────────────────────────
       ARTICLE WRAP
    ───────────────────────────────────────────────────────────── */

    .article-wrap {
      max-width: 760px;
      margin: 0 auto;
      padding: 4rem 1.5rem 6rem;
    }

    /* ─────────────────────────────────────────────────────────────
       ARTICLE HEADER
    ───────────────────────────────────────────────────────────── */

    .article-header {
      margin-bottom: 3rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--border);
    }

    .article-meta {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
      align-items: center;
      margin-bottom: 1.2rem;
    }

    /* BlogPost.astro と同一のタグスタイル */
    .article-tag {
      background: var(--amber-light);
      color: var(--amber);
      padding: .3rem .7rem;
      border-radius: 4px;
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .04em;
    }

    /* 面接回数バッジ — 黒地でシリーズ感を出す */
    .article-session {
      background: var(--ink);
      color: var(--paper);
      padding: .3rem .7rem;
      border-radius: 4px;
      font-family: "Syne", sans-serif;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .1em;
    }

    /* 被面接AI名バッジ */
    .article-subject {
      border: 1px solid var(--border-mid);
      color: var(--ink-muted);
      padding: .28rem .65rem;
      border-radius: 4px;
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .04em;
    }

    .article-date {
      font-size: .8rem;
      color: var(--ink-muted);
      margin-left: auto;
    }

    /* BlogPost.astro と同一のタイトルスタイル */
    .article-title {
      font-family: "Noto Serif JP", serif;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      line-height: 1.5;
      margin-bottom: 1rem;
      color: var(--ink);
    }

    .article-desc {
      color: var(--ink-muted);
      line-height: 1.9;
      font-size: 1rem;
    }

    /* 面接概要テーブル */
    .article-overview {
      margin-top: 2rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }

    .overview-cell {
      background: var(--paper-card);
      padding: .9rem 1.1rem;
      display: flex;
      flex-direction: column;
      gap: .3rem;
    }

    .overview-cell + .overview-cell {
      border-left: 1px solid var(--border);
    }

    .overview-cell-label {
      font-size: .6rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--ink-muted);
    }

    .overview-cell-value {
      font-family: "Noto Serif JP", serif;
      font-size: .9rem;
      font-weight: 500;
      color: var(--ink);
      line-height: 1.5;
    }

    /* ─────────────────────────────────────────────────────────────
       ARTICLE BODY — 通常散文は BlogPost.astro と同一
    ───────────────────────────────────────────────────────────── */

    .article-body {
      color: var(--ink);
    }

    .article-body p {
      font-size: 1.05rem;
      line-height: 2.15;
      color: var(--ink-soft);
      margin-bottom: 1.8rem;
    }

    .article-body strong {
      color: var(--ink);
      font-weight: 700;
    }

    .article-body hr {
      border: 0;
      border-top: 1px solid var(--border);
      margin: 3rem 0;
    }

    /* h2 — BlogPost.astro と同一 */
    .article-body h2 {
      font-family: "Noto Serif JP", serif;
      font-size: 1.45rem;
      line-height: 1.6;
      color: var(--ink);
      margin-top: 4rem;
      margin-bottom: 1.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      position: relative;
    }

    .article-body h2::before {
      content: "";
      position: absolute;
      top: -1px;
      left: 0;
      width: 60px;
      height: 2px;
      background: var(--amber);
    }

    /* h3 — BlogPost.astro と同一 */
    .article-body h3 {
      font-size: 1.15rem;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      border-left: 3px solid var(--amber);
      padding-left: .8rem;
    }

    .article-body ul,
    .article-body ol {
      margin: 1.5rem 0;
      padding-left: 1.5rem;
      line-height: 2;
    }

    .article-body li {
      font-size: 1rem;
      margin-bottom: .5rem;
      color: var(--ink-soft);
    }

    .article-body code {
      background: #efefef;
      padding: .15rem .35rem;
      border-radius: 4px;
      font-size: .9em;
    }

    /* ─────────────────────────────────────────────────────────────
       NEXT PREVIEW LINK — 次回予告ブロック
    ───────────────────────────────────────────────────────────── */

    :global(.article-body .next-preview) {
      display: block;
      margin-top: 3rem;
      padding: 1.4rem 1.6rem;
      background: var(--paper-card);
      border: 1px solid var(--border);
      border-left: 3px solid var(--amber);
      border-radius: 4px;
      text-decoration: none;
      transition: border-color .15s, background .15s;
    }

    :global(a.next-preview:hover) {
      border-left-color: var(--ink);
      background: #f3f0e9;
    }

    :global(.next-preview-label) {
      display: block;
      font-size: .62rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: .5rem;
    }

    :global(.next-preview-title) {
      display: block;
      font-family: "Noto Serif JP", serif;
      font-size: 1rem;
      color: var(--ink);
      line-height: 1.7;
    }

    :global(.next-preview-arrow) {
      display: inline-block;
      margin-top: .6rem;
      font-size: .8rem;
      color: var(--amber);
      font-weight: 700;
    }

    /* ─────────────────────────────────────────────────────────────
       FOOTER — BlogPost.astro と同構造
    ───────────────────────────────────────────────────────────── */

    .article-footer {
      max-width: 760px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .footer-back {
      color: var(--amber);
      font-weight: 700;
      font-size: .9rem;
      transition: opacity .15s;
    }

    .footer-back:hover {
      opacity: .75;
    }

    .footer-series-note {
      font-size: .75rem;
      color: var(--ink-muted);
      text-align: right;
      line-height: 1.7;
    }

    .footer-links {
      display: flex;
      gap: 1.5rem;
    }

    .footer-link {
      font-size: .8rem;
      color: var(--ink-muted);
      transition: color .15s;
    }

    .footer-link:hover {
      color: var(--amber);
    }

    /* ─────────────────────────────────────────────────────────────
       RESPONSIVE
    ───────────────────────────────────────────────────────────── */

    @media (max-width: 640px) {
      .article-wrap {
        padding: 2.5rem 1.25rem 5rem;
      }

      .article-title {
        font-size: 1.6rem;
      }

      .article-body p {
        font-size: 1rem;
      }

      .article-body h2 {
        font-size: 1.25rem;
      }

      .article-overview {
        grid-template-columns: repeat(2, 1fr);
      }

      .article-overview .overview-cell:nth-child(2) {
        border-left: 1px solid var(--border);
      }

      .article-overview .overview-cell:nth-child(3) {
        border-left: none;
        border-top: 1px solid var(--border);
        grid-column: 1 / -1;
      }

      .article-footer {
        flex-direction: column;
        align-items: flex-start;
        gap: .8rem;
      }

      .footer-series-note {
        text-align: left;
      }
    }
  </style>
</head>

<body>

  <!-- SITE HEADER -->
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">AI<span>との付き合い方</span>研究所</a>
      <a href="/blog/ai-interview" class="back-link">← 記事一覧</a>
    </div>
  </header>

  <!-- SERIES BAND -->
  <div class="series-band">
    <div class="series-band-inner">
      <span class="series-band-label">AI採用面接シリーズ</span>
      <span class="series-band-divider"></span>
      <span class="series-band-sub">AIを「採用面接の目」で評価する</span>
    </div>
  </div>

  <!-- ARTICLE -->
  <article>
    <div class="article-wrap">

      <header class="article-header">

        <div class="article-meta">
          <span class="article-tag">
            {frontmatter.tags?.[0] ?? "AI採用面接"}
          </span>

          {sessionLabel && (
            <span class="article-session">{sessionLabel}</span>
          )}

          {frontmatter.subject && (
            <span class="article-subject">{frontmatter.subject}</span>
          )}

          {date && (
            <time class="article-date">{date}</time>
          )}
        </div>

        <h1 class="article-title">
          {frontmatter.title}
        </h1>

        {frontmatter.description && (
          <p class="article-desc">
            {frontmatter.description}
          </p>
        )}

        <!-- 面接概要グリッド：frontmatter に値があれば自動表示 -->
        {(frontmatter.subject || frontmatter.theme || frontmatter.duration) && (
          <div class="article-overview">
            {frontmatter.subject && (
              <div class="overview-cell">
                <span class="overview-cell-label">被面接者</span>
                <span class="overview-cell-value">{frontmatter.subject}</span>
              </div>
            )}
            {frontmatter.theme && (
              <div class="overview-cell">
                <span class="overview-cell-label">評価テーマ</span>
                <span class="overview-cell-value">{frontmatter.theme}</span>
              </div>
            )}
            {frontmatter.duration && (
              <div class="overview-cell">
                <span class="overview-cell-label">面接時間</span>
                <span class="overview-cell-value">{frontmatter.duration}</span>
              </div>
            )}
          </div>
        )}

      </header>

      <div class="article-body">
        <slot />
      </div>

    </div>
  </article>

  <!-- FOOTER -->
  <footer class="article-footer">
    <a href="/blog/ai-interview" class="footer-back">← 記事一覧へ戻る</a>
    <nav class="footer-links">
      <a href="/about" class="footer-link">このサイトについて</a>
      <a href="/privacy" class="footer-link">プライバシーポリシー</a>
    </nav>
  </footer>

</body>
</html>