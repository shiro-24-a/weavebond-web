---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ズボラ人間のAI相棒術 | Weavebond">
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Noto+Serif+JP:wght@400;600&family=Noto+Sans+JP:wght@400;500&display=swap" rel="stylesheet">

	<main>
		<header class="hero">
			<div class="site-label">WEAVEBOND.COM</div>
			<h1 class="hero-title">
				ズボラ人間の<br>
				<em>AI相棒術</em>
			</h1>
			<p class="hero-lead">
				「がんばらない」を極める。綺麗なプロンプト論は無視してAIを使い倒し、<br class="br-pc">
				維持費ゼロの資産要塞を建築する——生存のためのリアルハック。
			</p>
			<div class="hero-rule"></div>
		</header>

		<section class="articles">

			<article class="card card-featured">
				<div class="card-inner">
					<div class="card-meta">
						<span class="tag">対話術</span>
						<span class="read-time">5 min read</span>
					</div>
					<h2 class="card-title">LINE感覚のAI対話術</h2>
					<p class="card-text">退屈なプロンプト論はゴミ箱へ。文法無視の「話し言葉」と「感情の垂れ流し」から、AIの最高出力を引き出すドロドロのラリー術。</p>
					<a class="card-link" href="#">記事を読む <span class="arrow">→</span></a>
				</div>
				<div class="card-number" aria-hidden="true">01</div>
			</article>

			<article class="card">
				<div class="card-meta">
					<span class="tag">デバッグ</span>
					<span class="read-time">4 min read</span>
				</div>
				<h2 class="card-title">思考停止の丸投げコピペ</h2>
				<p class="card-text">エラーが出たら1秒も調べるな。画面をそのまま貼り付けてAIにデバッグさせる、思考コストを極限まで削ったズボラ解決のリアル。</p>
				<a class="card-link" href="#">記事を読む <span class="arrow">→</span></a>
				<div class="card-number" aria-hidden="true">02</div>
			</article>

			<article class="card">
				<div class="card-meta">
					<span class="tag">インフラ</span>
					<span class="read-time">7 min read</span>
				</div>
				<h2 class="card-title">維持費ゼロの要塞建築</h2>
				<p class="cache-title card-title">維持費ゼロの要塞建築</h2>
				<p class="card-text">Astro×Cloudflareで実現する、赤字リスク完全ゼロのWebサイト構築。うつの時期でも勝ねネットの海を漂う資産の作り方。</p>
				<a class="card-link" href="#">記事を読む <span class="arrow">→</span></a>
				<div class="card-number" aria-hidden="true">03</div>
			</article>

		</section>
	</main>
</Layout>

<style is:global>
	/* 特殊な不可視空白文字を完全に排除し、クリーンなCSS変数に修正 */
	:root {
		--ink: #0e0d0b;
		--ink-muted: #6b6860;
		--paper: #f5f2ec;
		--paper-card: #faf8f4;
		--amber: #c87c22;
		--border: rgba(14, 13, 11, 0.12);
	}

	*, *::before, *::after { box-sizing: border-box; }

	body {
		background-color: var(--paper) !important;
		margin: 0;
		font-family: 'Noto Sans JP', sans-serif;
		color: var(--ink);
		-webkit-font-smoothing: antialiased;
	}

	a { color: inherit; text-decoration: none; }

	main {
		max-width: 1040px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* ── HERO ── */
	.hero { padding: 5rem 0 4rem; }

	.site-label {
		font-family: 'Syne', sans-serif;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		color: var(--amber);
		margin-bottom: 2.5rem;
		text-transform: uppercase;
	}

	.hero-title {
		font-family: 'Noto Serif JP', serif;
		font-size: clamp(2.8rem, 6vw, 4.8rem);
		font-weight: 600;
		line-height: 1.15;
		letter-spacing: -0.01em;
		color: var(--ink);
		margin: 0 0 2rem 0;
	}

	.hero-title em {
		font-style: normal;
		color: var(--amber);
	}

	.hero-lead {
		font-size: 1.05rem;
		color: var(--ink-muted);
		line-height: 2;
		max-width: 600px;
		margin: 0 0 3rem 0;
	}

	.hero-rule {
		width: 100%;
		height: 1px;
		background: var(--border);
	}

	/* ── GRID ── */
	.articles {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5px;
		background: var(--border);
		margin-top: 1.5px;
		border-bottom: 1.5px solid var(--border);
	}

	/* ── CARD ── */
	.card {
		background: var(--paper-card);
		padding: 2.5rem;
		position: relative;
		overflow: hidden;
		transition: background 0.25s ease;
		cursor: pointer;
	}

	.card:hover { background: #ffffff; }

	.card-featured {
		grid-column: span 2;
		display: flex;
		align-items: center;
		gap: 2rem;
		border-bottom: 1.5px solid var(--border);
		overflow: visible;
	}

	.card-featured .card-inner {
		flex: 1;
		min-width: 0;
	}

	.card-featured .card-title {
		font-size: clamp(1.6rem, 3vw, 2.2rem);
	}

	.card-featured .card-number {
		position: static;
		font-size: 8rem;
		color: rgba(14, 13, 11, 0.05);
		flex-shrink: 0;
	}

	/* ── CARD PARTS ── */
	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
	}

	.tag {
		font-family: 'Syne', sans-serif;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--amber);
		background: rgba(200, 124, 34, 0.1);
		padding: 0.2rem 0.6rem;
		border-radius: 2px;
	}

	.read-time {
		font-size: 0.75rem;
		color: var(--ink-muted);
	}

	.card-title {
		font-family: 'Noto Serif JP', serif;
		font-size: 1.35rem;
		font-weight: 600;
		line-height: 1.4;
		color: var(--ink);
		margin: 0 0 1rem 0;
		letter-spacing: 0.01em;
	}

	.card-text {
		font-size: 0.9rem;
		color: var(--ink-muted);
		line-height: 1.85;
		margin: 0 0 1.75rem 0;
	}

	.card-link {
		font-family: 'Syne', sans-serif;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		border-bottom: 1px solid var(--ink);
		padding-bottom: 1px;
		transition: color 0.2s, border-color 0.2s;
	}

	.card-link:hover {
		color: var(--amber);
		border-color: var(--amber);
	}

	.arrow {
		display: inline-block;
		transition: transform 0.2s ease;
	}

	.card:hover .arrow { transform: translateX(4px); }

	.card-number {
		font-family: 'Syne', sans-serif;
		font-size: 5rem;
		font-weight: 800;
		color: rgba(14, 13, 11, 0.05);
		line-height: 1;
		letter-spacing: -0.04em;
		user-select: none;
		position: absolute;
		bottom: 1.25rem;
		right: 1.75rem;
	}

	/* ── RESPONSIVE ── */
	@media (max-width: 720px) {
		.hero { padding: 3rem 0 2.5rem; }
		.br-pc { display: none; }

		.articles { grid-template-columns: 1fr; }

		.card-featured {
			grid-column: span 1;
			flex-direction: column;
			align-items: flex-start;
		}

		.card-featured .card-number { display: none; }

		.card { padding: 2rem 1.5rem; }
	}
</style>