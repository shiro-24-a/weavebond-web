---

// src/layouts/BlogPost.astro

const { frontmatter } = Astro.props;

const date = frontmatter.pubDate
? new Date(frontmatter.pubDate).toLocaleDateString("ja-JP", {
year: "numeric",
month: "long",
day: "numeric",
})
: null;
---

<!DOCTYPE html>

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{frontmatter.title} | AIとの付き合い方研究所</title>

{frontmatter.description && ( <meta name="description" content={frontmatter.description} />
)}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Noto+Serif+JP:wght@400;500;600&family=Noto+Sans+JP:wght@400;500&display=swap');

    :root {
      --ink: #111111;
      --ink-soft: #2b2b2b;
      --ink-muted: #666666;

      --paper: #f7f4ee;
      --paper-card: #fcfaf6;

      --amber: #c87c22;
      --amber-line: rgba(200,124,34,.35);

      --border: rgba(0,0,0,.10);
      --border-mid: rgba(0,0,0,.18);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: "Noto Sans JP", sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* HEADER */

    .site-header {
      border-bottom: 1px solid var(--border);
      background: rgba(247,244,238,.95);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .site-header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1rem 1.5rem;

      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .site-logo {
      font-family: "Noto Serif JP", serif;
      font-size: .85rem;
      font-weight: 600;
      color: var(--ink-soft);
      letter-spacing: .06em;
    }

    .site-logo span {
      color: var(--amber);
    }

    .back-link {
      font-size: .8rem;
      color: var(--ink-muted);
    }

    /* ARTICLE */

    .article-wrap {
      max-width: 760px;
      margin: 0 auto;
      padding: 4rem 1.5rem 6rem;
    }

    .article-header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    .article-meta {
      display: flex;
      gap: .8rem;
      align-items: center;
      margin-bottom: 1rem;
    }

    .article-tag {
      background: rgba(200,124,34,.08);
      color: var(--amber);
      padding: .3rem .7rem;
      border-radius: 4px;
      font-size: .7rem;
      font-weight: 700;
    }

    .article-date {
      font-size: .8rem;
      color: var(--ink-muted);
    }

    .article-title {
      font-family: "Noto Serif JP", serif;
      font-size: clamp(1.8rem,4vw,2.5rem);
      line-height: 1.5;
      margin-bottom: 1rem;
      color: var(--ink);
    }

    .article-desc {
      color: var(--ink-muted);
      line-height: 1.9;
    }

    /* 本文 */

    .article-body {
      color: var(--ink);
    }

  .article-body p {
  font-size: 1.05rem;
  line-height: 2.15;
  color: var(--ink-soft);
  margin-bottom: 1.8rem;
}

    .article-body strong {
      color: var(--ink);
      font-weight: 700;
    }

    .article-body hr {
      border: 0;
      border-top: 1px solid var(--border);
      margin: 3rem 0;
    }

    .article-body h2 {
      font-family: "Noto Serif JP", serif;
      font-size: 1.45rem;
      line-height: 1.6;
      color: var(--ink);

      margin-top: 4rem;
      margin-bottom: 1.5rem;

      padding-top: 2rem;

      border-top: 1px solid var(--border);
      position: relative;
    }

    .article-body h2::before {
      content: "";
      position: absolute;
      top: -1px;
      left: 0;
      width: 60px;
      height: 2px;
      background: var(--amber);
    }

    .article-body h3 {
      font-size: 1.15rem;
      margin-top: 2.5rem;
      margin-bottom: 1rem;

      border-left: 3px solid var(--amber);
      padding-left: .8rem;
    }

    :global(.article-body blockquote) {
      background: var(--paper-card);
      border-left: 3px solid var(--amber);
      padding: 1.3rem 1.5rem;
      margin: 2rem 0;
      border-radius: 4px;
    }

   :global(.article-body blockquote p) {
  margin: 0 0 1rem 0;
  color: #555;
}

:global(.article-body blockquote p:last-child) {
  margin-bottom: 0;
}

    .article-body ul,
    .article-body ol {
      margin: 1.5rem 0;
      padding-left: 1.5rem;
      line-height: 2;
    }

    .article-body li {
      margin-bottom: .5rem;
    }

    .article-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: white;
    }

    .article-body th,
    .article-body td {
      border: 1px solid #ddd;
      padding: .8rem;
      text-align: left;
    }

    .article-body th {
      background: #f5f5f5;
    }

    .article-body code {
      background: #efefef;
      padding: .15rem .35rem;
      border-radius: 4px;
    }

    /* FOOTER */

    .article-footer {
      max-width: 760px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .footer-back {
      color: var(--amber);
      font-weight: 700;
    }

    .footer-links {
      display: flex;
      gap: 1.5rem;
    }

    .footer-link {
      font-size: .8rem;
      color: var(--ink-muted);
      transition: color .15s;
    }

    .footer-link:hover {
      color: var(--amber);
    }

    @media (max-width: 640px) {
      .article-wrap {
        padding: 2.5rem 1.25rem 5rem;
      }

      .article-title {
        font-size: 1.6rem;
      }

      .article-body p {
        font-size: 1rem;
      }

      .article-body h2 {
        font-size: 1.25rem;
      }
    }
  </style>

</head>

<body>

  <header class="site-header">
    <div class="site-header-inner">
   <a href="/" class="site-logo">AI<span>との付き合い方</span>研究所</a>
      <a href="/" class="back-link">← 記事一覧</a>
    </div>
  </header>

  <article>
  <div class="article-wrap">

<header class="article-header">
    <div class="article-meta">
      <span class="article-tag">
        {frontmatter.tags?.[0] ?? "記事"}
      </span>

      {date && (
        <time class="article-date">{date}</time>
      )}
    </div>

    <h1 class="article-title">
      {frontmatter.title}
    </h1>

    {frontmatter.description && (
      <p class="article-desc">
        {frontmatter.description}
      </p>
    )}
  </header>

 <div class="article-body">
  <slot />
</div>

</div>

</article>

<footer class="article-footer">
    <a href="/" class="footer-back">
      ← 記事一覧へ戻る
    </a>
    <nav class="footer-links">
      <a href="/about" class="footer-link">このサイトについて</a>
      <a href="/privacy" class="footer-link">プライバシーポリシー</a>
    </nav>
  </footer>

</body>
</html>